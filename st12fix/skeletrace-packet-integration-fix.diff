+fn load_packet_events(path: PathBuf) -> Result<Vec<PacketEvent>, OperatorError> {
+    let bytes = fs::read(path).map_err(|err| OperatorError::Io(err.to_string()))?;
+    let text = std::str::from_utf8(&bytes)
+        .map_err(|err| OperatorError::Serde(err.to_string()))?;
+    let trimmed = text.trim();
+    if trimmed.is_empty() {
+        return Ok(Vec::new());
+    }
+
+    if trimmed.starts_with('[') {
+        return serde_json::from_str(trimmed)
+            .map_err(|err| OperatorError::Serde(err.to_string()));
+    }
+
+    if trimmed.starts_with('{') {
+        if let Ok(single) = serde_json::from_str::<PacketEvent>(trimmed) {
+            return Ok(vec![single]);
+        }
+    }
+
+    let mut events = Vec::new();
+    for (idx, line) in text.lines().enumerate() {
+        let line = line.trim();
+        if line.is_empty() {
+            continue;
+        }
+        let event = serde_json::from_str::<PacketEvent>(line)
+            .map_err(|err| OperatorError::Serde(format!("invalid packet event at line {}: {err}", idx + 1)))?;
+        events.push(event);
     }
+    Ok(events)
 }
 
